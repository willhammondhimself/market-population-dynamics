    "import random\n",
    "\n",
    "def game():\n",
    "    a = random.uniform(0,1)\n",
    "    b = random.uniform(0,1)\n",
    "\n",
    "    if a < 0.5:\n",
    "        a = random.uniform(0,1)\n",
    "\n",
    "    if b < 0.625:\n",
    "        b = random.uniform(0,1)\n",
    "\n",
    "    return a if a>b else b"
   ]
